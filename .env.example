# Postgres connection string.
# Local dev (matches the README's local setup): postgres://YOUR_MAC_USERNAME@localhost:5432/sunday_runs_dev
# Production (Supabase): copy the "Connection string" (URI, with password) from
# Project Settings -> Database in your Supabase dashboard.
DATABASE_URL=

# Name of the cookie used to store the session token.
SESSION_COOKIE_NAME=sr_session

# Web push (waitlist-promotion notifications). Generate a pair with:
#   npx web-push generate-vapid-keys
# The public key is not secret — NEXT_PUBLIC_VAPID_PUBLIC_KEY must match VAPID_PUBLIC_KEY exactly.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
